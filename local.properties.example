# Copy this file to local.properties and fill in your values.
# local.properties is gitignored and must never be committed.

# API key for authenticating requests to the location endpoint
API_KEY=your_api_key_here

# Full URL of the location API endpoint
API_URL=https://your-server.example.com/api/location

# Device identifier sent with every location update
DEVICE_ID=your_device_id_here
